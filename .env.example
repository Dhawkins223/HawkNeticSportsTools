KALSHI_ENV=demo
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Sports odds API remains optional; scraper mode is preferred by default.
ODDS_API_KEY=
THE_ODDS_API_KEY=
SPORTSDATA_API_KEY=

# Firecrawl scraper/source snapshots.
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=

# Railway runtime and future hosted database wiring.
# Keep actual values in Railway Variables or local .env only.
# Set to a Railway volume mount such as /data so reports, cache, and SQLite persist across deploys.
RESEARCH_DATA_DIR=
DATABASE_BACKEND=sqlite
EVALUATION_DB_PATH=data/evaluation.sqlite
DATABASE_URL=
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=5
DATABASE_MIGRATION_MODE=check
RAILWAY_ENVIRONMENT=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=

# Hosted public API fetch safety.
# These prevent public Kalshi/ESPN refreshes from hammering sources.
KALSHI_HTTP_CACHE_TTL_SECONDS=900
KALSHI_HTTP_MAX_RETRIES=2
KALSHI_HTTP_BACKOFF_SECONDS=2
KALSHI_HTTP_MIN_INTERVAL_SECONDS=0.25
KALSHI_HTTP_ALLOW_STALE_ON_ERROR=false
KALSHI_HTTP_MAX_STALE_SECONDS=7200
KALSHI_RUNTIME_CLEANUP_ENABLED=true
KALSHI_HTTP_CACHE_MAX_AGE_SECONDS=21600
KALSHI_HTTP_CACHE_MAX_BYTES=268435456

# Optional dashboard auth for public Railway/mobile access.
# Local dashboard stays open if DASHBOARD_AUTH_PASSWORD is blank.
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_REQUIRE_AUTH_WHEN_HOSTED=true
DASHBOARD_AUTH_USERNAME=hawknetic
DASHBOARD_AUTH_PASSWORD=
DASHBOARD_BASIC_FALLBACK_ENABLED=true
DASHBOARD_BASIC_AUTH_ROLE=admin
DASHBOARD_USER_AUTH_ENABLED=false
AUTH_DB_PATH=data/evaluation.sqlite
AUTH_SESSION_MINUTES=480
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCK_MINUTES=15
AUTH_REGISTRATION_ENABLED=false
# Used only for one local auth-create-user invocation; remove it immediately afterward.
AUTH_NEW_USER_PASSWORD=

# Private operator/Codex instruction inbox. This queue stores messages for manual
# review only; it never executes commands, edits code, deploys, or trades.
OPERATOR_NAME=owner
OPERATOR_INBOX_DB_PATH=data/evaluation.sqlite
DASHBOARD_MAX_SLIP_AGE_SECONDS=1800

# Optional Google Drive report/archive connector.
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_REPORT_FOLDER=Research Bots

# Optional Airtable operational status connector.
AIRTABLE_ENABLED=false
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_BOT_RUNS_TABLE=Bot Runs
AIRTABLE_SOURCE_HEALTH_TABLE=Source Health
AIRTABLE_STAGE_GATES_TABLE=Stage Gates
AIRTABLE_OPEN_ISSUES_TABLE=Open Issues

# Optional Slack alert connector.
SLACK_ALERTS_ENABLED=false
SLACK_WEBHOOK_URL=

# Private sports source collection.
SPORTS_SOURCE_MODE=scraper
SPORTS_SCRAPER_ENABLED=true

# Private always-on local scheduler/watchdog.
RESEARCH_DAEMON_ENABLED=false
RESEARCH_DASHBOARD_PORT=8765
CRYPTO_RUN_ID=crypto_private_20260704
SPORTS_RUN_ID=sports_private_20260704
KALSHI_RUN_ID=stage3a_20260703_170707
BOT_COMPANY_ENABLED=true
EXTERNAL_SOURCES_CONFIG=config/sources.json

# Authenticated account handoff remains disabled.
KALSHI_ORDER_UPLOAD_ENABLED=false

# Explicitly disabled public/product connectors for now.
VERCEL_ENABLED=false
POSTHOG_ENABLED=false
STRIPE_ENABLED=false
